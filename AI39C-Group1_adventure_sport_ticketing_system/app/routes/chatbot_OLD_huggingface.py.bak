from flask import Blueprint, request, jsonify, current_app
import requests, os

chatbot_bp = Blueprint('chatbot', __name__)

# Environment variable for HuggingFace API token (set in .env)
HF_API_TOKEN = os.getenv('HUGGINGFACE_API_TOKEN')
HF_API_URL = 'https://api-inference.huggingface.co/models/google/flan-t5-base'

@chatbot_bp.route('/chat', methods=['POST'])
def chat():
    data = request.get_json()
    if not data or 'message' not in data:
        return jsonify({'error': 'No message provided'}), 400
    user_msg = data['message']
    headers = {"Authorization": f"Bearer {HF_API_TOKEN}"} if HF_API_TOKEN else {}
    payload = {"inputs": user_msg}
    try:
        response = requests.post(HF_API_URL, headers=headers, json=payload, timeout=10)
        response.raise_for_status()
        result = response.json()
        # The API returns a list with generated text in 'generated_text'
        if isinstance(result, list) and 'generated_text' in result[0]:
            bot_reply = result[0]['generated_text']
        else:
            bot_reply = "I'm having trouble understanding. Please try again."
    except Exception as e:
        current_app.logger.error(f"Chatbot API error: {e}")
        bot_reply = "Sorry, I'm unable to respond right now."
    return jsonify({'reply': bot_reply})
